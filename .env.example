# Sentence assembly uses Gemini (Google AI Studio — free tier at aistudio.google.com).
# Optional: without a key, Emla falls back to a deterministic gloss-to-text join.
GEMINI_API_KEY=your_gemini_api_key_here

PORT=8000
FRONTEND_URL=http://localhost:5173
CONFIDENCE_THRESHOLD=0.65
PAUSE_FRAMES=15
SEQUENCE_LENGTH=30
